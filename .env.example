# ============================================
# REQUERIDAS
# ============================================

# Base de datos PostgreSQL central
POSTGRES_HOST=postgres_central
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel_user
POSTGRES_PASSWORD=cambia-esta-password

# Bot de Telegram para notificaciones
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# ============================================
# OPCIONALES (con defaults)
# ============================================

# API key para Woot (solicitar en: https://forums.woot.com/t/request-developer-api-key/734283)
# Sin este valor el WootCollector se saltea
WOOT_API_KEY=

# Intervalo de polling del collector Woot (segundos)
WOOT_INTERVAL_SECONDS=60

# Intervalo de polling del collector Reddit (segundos)
REDDIT_INTERVAL_SECONDS=600

# Canales de Telegram a monitorear (separados por coma, sin @)
# Ejemplo: kindle_deals,ebook_offers
TELEGRAM_CHANNELS=

# Intervalo de polling del collector Telegram (segundos)
TELEGRAM_INTERVAL_SECONDS=300

# Cantidad maxima de observaciones por ciclo de collect (evita DoS)
MAX_OBSERVATIONS_PER_CYCLE=500

# Hora UTC del heartbeat diario (9 AM Bogota = 14 UTC)
HEARTBEAT_HOUR_UTC=14

# Hora UTC del resumen diario (10 PM Bogota = 3 UTC)
SUMMARY_HOUR_UTC=3

# Nivel de logging
LOG_LEVEL=INFO
